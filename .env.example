# 統一期貨 Unitrade API 設定
# 複製此檔為 .env 並填入真實值

DRY_RUN=true   # true=模擬模式（不下單）false=真實下單

UNITRADE_URL=https://test167.pfctrade.com   # 測試環境；正式環境換成正式 URL
UNITRADE_USERID=你的帳號
UNITRADE_PASSWORD=你的密碼
UNITRADE_CA_PATH=./憑證.pfx
UNITRADE_CA_PASSWORD=憑證密碼
UNITRADE_PRODUCT=MXFG5                      # 要訂閱的商品代碼（小台指近月）

# Telegram 通知（與 MTX Monitor 共用同一個 bot 即可）
TELEGRAM_BOT_TOKEN=你的bot_token
TELEGRAM_CHAT_ID=你的chat_id
